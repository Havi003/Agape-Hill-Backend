# Copy to .env.production only for local production-mode testing.
# Render secrets belong in Render's protected Environment settings.
PORT=10000

DB_HOST=replace-with-production-database-host
DB_PORT=5432
DB_NAME=replace-with-production-database-name
DB_SCHEMA=school
DB_USERNAME=replace-with-production-database-user
DB_PASSWORD=replace-with-production-database-password

R2DBC_LOG_LEVEL=INFO
R2DBC_QUERY_LOG_LEVEL=INFO
R2DBC_PARAMETER_LOG_LEVEL=INFO

MPESA_BASE_URL=https://sandbox.safaricom.co.ke
MPESA_CONSUMER_KEY=replace-with-production-consumer-key
MPESA_CONSUMER_SECRET=replace-with-production-consumer-secret
MPESA_SHORT_CODE=replace-with-production-short-code
MPESA_CONFIRMATION_URL=https://replace-with-render-service.onrender.com/api/mpesa/confirmation
MPESA_VALIDATION_URL=https://replace-with-render-service.onrender.com/api/mpesa/validation
MPESA_RESPONSE_TYPE=Completed
