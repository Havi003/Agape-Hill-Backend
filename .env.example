# Copy to .env and fill local-only values. Never commit .env.
PORT=8080
FRONTEND_URL=http://localhost:5173

DB_HOST=localhost
DB_PORT=5432
DB_NAME=agape_hill_db
DB_SCHEMA=school
DB_USERNAME=postgres
DB_PASSWORD=replace-with-local-password

R2DBC_LOG_LEVEL=DEBUG
R2DBC_QUERY_LOG_LEVEL=DEBUG
R2DBC_PARAMETER_LOG_LEVEL=DEBUG

MPESA_BASE_URL=https://sandbox.safaricom.co.ke
MPESA_CONSUMER_KEY=replace-with-sandbox-consumer-key
MPESA_CONSUMER_SECRET=replace-with-sandbox-consumer-secret
MPESA_SHORT_CODE=replace-with-sandbox-short-code
MPESA_CONFIRMATION_URL=http://localhost:8080/api/mpesa/confirmation
MPESA_VALIDATION_URL=http://localhost:8080/api/mpesa/validation
MPESA_RESPONSE_TYPE=Completed
